# ============================================================
# trader-claude environment variables
# Copy this file to .env and fill in your values
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=trader
MYSQL_USER=trader
MYSQL_PASSWORD=traderpassword
MYSQL_PORT=3306

# --- Redis ---
REDIS_PORT=6379

# --- Backend ---
BACKEND_PORT=8080
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=debug

# Database DSN (auto-constructed from MYSQL_* vars if not set directly)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trader
DB_USER=trader
DB_PASSWORD=traderpassword
DB_DSN=

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_DB=0

# Worker pool
WORKER_POOL_SIZE=10

# JWT (for future auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# --- Market data providers (Phase 2+) ---
# Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# News APIs
NEWSAPI_KEY=
ALPHAVANTAGE_KEY=
